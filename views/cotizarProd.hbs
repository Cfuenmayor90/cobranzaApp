<nav class="navegacion">
  <a href="javascript:history.back()"><i class="bi bi-box-arrow-left"></i></a>
  <div>
    <span>Detalles Del Producto</span>
  </div>
  <div class="iconMenuHamburguesa">
    <i class="bi bi-menu-button-wide-fill"></i>
  </div>
</nav>
<div class="contMayorCli">
  <div class="formCliente">
   
        <img class="imgCotizarProd" src="/uploads/{{prod.cod}}.jpg" alt="">
        <div class="divTitleProd">
        <h2>{{prod.nombre}}</h2>
        </div>
    <div class="infoCotizarProd" >
       <h4>Codigo: {{prod.cod}}</h4>
       <h4>Disponibles: {{prod.stock}}</h4>
       <h2 style="font-size: 25px;">Precio: <label for="" style="color: blue;">{{precioTartj}}</label></h2>
       <h2 style="font-size: 25px;">Efectivo: <label for="" style="color: rgb(0, 145, 31);">{{precio}}</label></h2>
     <h5>{{prod.descripcion}}</h5>
     <br>
    
        <a href="https://wa.me/5493855349020/?text=Hola%20deseo%20comprar%20el%20producto%20{{prod.nombre}}%20Code:%20{{prod.cod}}" ><h4 class="btnComprar">Comprar</h4></a>
    
     
       </div>  
              <table class="tableCreditCard">
           <tr class="trTitleCreditCard">
            <th colspan="5" class="thTitleCreditCard">Promociones Con Tarjeta De Credito</th>
           </tr>
           <tr class="trCreditCard">
          
            <th colspan="2">Tarjeta</th>
            <th>Cuotas</th>
            <th>Cuota</th>
            <th>Total</th>
           </tr>
            {{#each arrayTarjetas}}
              <tr class="trCreditCard">
                  <th><img src="/{{tarjeta}}.svg" alt=""></th>
                  <th>{{nombre}}</th>
                  <th>{{cuotas}}</th>
                  <th>{{cuota}}</th>
                  <th>{{total}}</th>
              </tr>
            {{/each}}
           <tr>

           </tr>
       </table>  
       
    
    </div>

  <div class="formCliente">
     <div class="divTitleProd">
      <h3 class="tituloForm">Planes De Pago Para Comerciantes</h3>
    </div>
    <div class="tarjUser"> 
      <table class="tableCreditCard">
        <tr class="">
          <th class="tableListCajaTitle">Plan</th>
          <th class="tableListCajaTitle">Cuotas</th>
          <th class="tableListCajaTitle">Valor De Cuota</th>
        </tr>
      {{#each arrayPlanes}}
          <tr>
            <th class="tableListCajaRes">{{plan}}</th>
            <th class="tableListCajaRes">{{cuotas}}</th>
            <th class="tableListCajaRes">{{cuota}}</th>
          </tr>
     {{/each}}
      </table>
      <h3 style="color: red; text-align: center;">Planes de pago con entrega de la 1° cuota</h3>
    </div>
         <div class="divTitleProd">
      <h3 class="tituloForm">Planes De Pago Para Particulares</h3>
    </div>
    <div class="tarjUser">
      <table class="tableCreditCard">
        <tr class="">
          <th class="tableListCajaTitle">Plan</th>
          <th class="tableListCajaTitle">Cuotas</th>
            <th class="tableListCajaTitle">Valor De Cuota</th>
         
           <th class="tableListCajaTitle">Total</th>
        </tr>
      {{#each arrayPlanesParticulares}}
          <tr>
            <th class="tableListCajaRes">{{plan}}</th>
            <th class="tableListCajaRes">{{cuotas}}</th>
            <th class="tableListCajaRes">{{cuota}}</th>
     
            <th class="tableListCajaRes">{{total}}</th>
          </tr>
     {{/each}}
      </table>
      <h3 style="color: red; text-align: center;">Planes de pago con entrega de la 1° cuota</h3>
    </div>
  </div>
  
  </div>