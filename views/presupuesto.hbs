<nav class="navegacion">
    <a href="javascript:history.back()"><i class="bi bi-box-arrow-left"></i></a>
    <div>
      <span>Presupuesto</span>
    </div>
    <div class="iconMenuHamburguesa">
      <i class="bi bi-menu-button-wide-fill"></i>
    </div>
  </nav>
   <div class="contMayorCli">
<div class="formCliente">
    <div class="divClienteBuscar">
        <h3 class="tituloForm">Cantidad De Productos</h3>
      </div>
    <form action="/calculadora/presupuestoProdFinal" method="post" class="formCliente2">

      <p>Ingresar Cantidad De Productos</p>
      <br />
 
      <label class="title" for="codProd">Codigo De Producto</label>
      <select type="text" class="inpForm"  id="codProd" name="codProd" multiple>
        {{#each arrayCod}}
           <option value="{{cod}}" selected>{{cod}}</option>
        {{/each}}
      </select>
        <br>
         <label class="title" for="telefono">Cantidad De Productos:</label>
        {{#each arrayCod}}
        <br>
      <input type="number" class="inpForm" style="width: 12%;" id="{{cod}}" name="{{cod}}" required/>
      <label class="title" for="">{{cod}} / {{nombre}}</label>
        {{/each}}
        <br>
     <br>

      <label class="title" for="descuento">Descuento Aplicado En %</label>
      <input type="number" class="inpForm" value="{{descuento}}" id="descuento" name="descuento" readonly/>
      <br />


      <div class="cantBtnForm">
    
        <a class="btnFormReset" href="javascript:history.back()"> Volver Atrás</a>

        <button class="btnFormAceptar" type="submit">Continuar</button>
      </div>
  
    </form>
</div>
   
  </div>